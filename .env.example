# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration - Google Cloud SQL
# Option 1: Cloud SQL Auth Proxy (recommended for local development)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/product_catalogue
# 
# Option 2: Cloud SQL public IP (less secure)
# DATABASE_URL=postgresql://postgres:password@YOUR_PUBLIC_IP:5432/product_catalogue
#
# Option 3: Cloud SQL Unix socket (when deployed on Cloud Run)
# DATABASE_URL=postgresql://postgres:password@/cloudsql/project:region:instance

DATABASE_URL=

# Google Cloud SQL Connection Name (format: project:region:instance)
CLOUD_SQL_CONNECTION_NAME=your-project:region:instance-name

# Google Cloud Storage Configuration
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
GCS_CREDENTIALS_FILE=/app/credentials.json
GCS_PUBLIC_URL_BASE=https://storage.googleapis.com/your-gcs-bucket-name
